{
  "uid": "pulsestream-service-health",
  "title": "Service Health",
  "tags": ["pulsestream"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(process_uptime_seconds, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=~\"$job\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"$job\"}",
          "legendFormat": "{{job}} process"
        },
        {
          "expr": "system_cpu_usage{job=~\"$job\"}",
          "legendFormat": "{{job}} system"
        }
      ]
    },
    {
      "id": 3,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=~\"$job\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Count",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$job\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
